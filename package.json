{
  "name": "scalability-sdk",
  "version": "2.1.0",
  "private": true,
  "description": "Scale Digital SDK — distribution repo (core + analytics, vanilla JS, CDN-shipped).",
  "scripts": {
    "build": "npm run build:core && npm run build:analytics",
    "build:core": "terser sdk/scale-sdk-v2.js --compress --mangle --comments false -o sdk/scale-sdk-v2.min.js",
    "build:analytics": "terser sdk/scale-analytics.js --compress --mangle --comments false -o sdk/scale-analytics.min.js",
    "sri": "bash scripts/compute-sri.sh",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "terser": "^5.37.0"
  }
}
